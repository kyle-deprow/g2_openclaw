# Azure AI Services API key for the G2 OpenClaw gateway (model-router).
#
# Retrieve with:
#   az cognitiveservices account keys list \
#     --name aisvc-ss-aisense-dev-eastus2 \
#     --resource-group rg-ss-aisense-dev-eastus \
#     --query key1 -o tsv
#
# Or find it in the Azure Portal under:
#   Cognitive Services → aisvc-ss-aisense-dev-eastus2 → Keys and Endpoint
AZURE_AI_SERVICES_API_KEY=
